generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum WeightUnit {
  KG
  LB
}

enum WorkoutLogStatus {
  DRAFT
  COMPLETED
}

enum SplitWeekday {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

model User {
  id                  String       @id @default(cuid())
  email               String       @unique
  username            String       @unique
  firstName           String?
  lastName            String?
  passwordHash        String
  preferredWeightUnit WeightUnit   @default(LB)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  workoutLogs         WorkoutLog[]
  exercises           Exercise[]
  workoutSplit        WorkoutSplit?
}

model Exercise {
  id               String            @id @default(cuid())
  userId           String
  name             String
  normalizedName   String
  lastPerformedAt  DateTime?         @db.Date
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  workoutExercises WorkoutExercise[]

  @@unique([userId, normalizedName])
  @@index([userId, lastPerformedAt])
}

model WorkoutLog {
  id              String            @id @default(cuid())
  userId          String
  title           String
  workoutType     String?
  workoutTypeSlug String?
  status          WorkoutLogStatus  @default(COMPLETED)
  totalWeightLb   Decimal           @default(0)
  performedAt     DateTime          @default(now()) @db.Date
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercises       WorkoutExercise[]

  @@index([userId, performedAt])
  @@index([userId, createdAt])
  @@index([userId, workoutTypeSlug])
}

model WorkoutExercise {
  id             String       @id @default(cuid())
  workoutLogId   String
  exerciseId     String?
  name           String
  normalizedName String       @default("")
  order          Int
  createdAt      DateTime     @default(now())
  workoutLog     WorkoutLog   @relation(fields: [workoutLogId], references: [id], onDelete: Cascade)
  exercise       Exercise?    @relation(fields: [exerciseId], references: [id], onDelete: SetNull)
  sets           WorkoutSet[]

  @@unique([workoutLogId, order])
  @@index([workoutLogId, normalizedName])
  @@index([normalizedName])
  @@index([exerciseId])
}

model WorkoutSet {
  id                String          @id @default(cuid())
  workoutExerciseId String
  order             Int
  reps              Int
  weightLb          Decimal?
  createdAt         DateTime        @default(now())
  workoutExercise   WorkoutExercise @relation(fields: [workoutExerciseId], references: [id], onDelete: Cascade)

  @@unique([workoutExerciseId, order])
  @@index([weightLb])
}

model WorkoutSplit {
  id        String            @id @default(cuid())
  userId    String            @unique
  name      String            @default("Weekly Split")
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  days      WorkoutSplitDay[]
}

model WorkoutSplitDay {
  id          String                 @id @default(cuid())
  splitId     String
  weekday     SplitWeekday
  workoutType String
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  split       WorkoutSplit           @relation(fields: [splitId], references: [id], onDelete: Cascade)
  exercises   WorkoutSplitExercise[]

  @@unique([splitId, weekday])
}

model WorkoutSplitExercise {
  id                  String          @id @default(cuid())
  splitDayId          String
  order               Int
  exerciseDisplayName String
  exerciseSlug        String
  sets                Int
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  splitDay            WorkoutSplitDay @relation(fields: [splitDayId], references: [id], onDelete: Cascade)

  @@unique([splitDayId, order])
  @@index([splitDayId, exerciseSlug])
}
